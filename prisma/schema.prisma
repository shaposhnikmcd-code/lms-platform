generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime       @default(now())
  lastLoginAt   DateTime?
  role          UserRole       @default(STUDENT)
  accounts      Account[]
  enrollments   Enrollment[]
  sessions      Session[]
  progress      CourseProgress[]
  lessonProgress LessonProgress[]
  payments      Payment[]
  certificates  Certificate[]
  subscriptions Subscription[]
  courseTeachers CourseTeacher[]
  sentMessages     Message[]   @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  news          News[]
  deletedAt      DateTime?
  deletedById    String?
  deletedByName  String?
  deletedByEmail String?

  @@index([role])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id           String           @id @default(cuid())
  title        String
  description  String
  price        Int
  published    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  imageUrl     String?
  slug         String?          @unique
  enrollments  Enrollment[]
  modules      Module[]
  progress     CourseProgress[]
  payments     Payment[]
  certificates Certificate[]
  courseTeachers CourseTeacher[]
  promoCodes    PromoCode[]
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  courseId   String?
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, read])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id             String           @id @default(cuid())
  title          String
  order          Int
  moduleId       String
  content        String?
  videoUrl       String?
  videoProvider  VideoProvider    @default(YOUTUBE)
  videoId        String?
  duration       Int?
  isFree         Boolean          @default(false)
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress[]
  lessonProgress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  watchedAt   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseProgress {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  lastLessonId    String?
  progressPercent Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lastLesson      Lesson?   @relation(fields: [lastLessonId], references: [id])

  @@unique([userId, courseId])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  courseId       String?
  bundleId       String?
  orderReference String        @unique
  amount         Int
  currency       String        @default("UAH")
  status         PaymentStatus @default(PENDING)
  /// Для CHOICE_FREE bundle-ів: слаги курсів, які клієнт обрав як безкоштовні
  freeSlugs      String[]      @default([])
  createdAt      DateTime      @default(now())
  paidAt         DateTime?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?       @relation(fields: [courseId], references: [id])
  bundle         Bundle?       @relation(fields: [bundleId], references: [id])

  @@index([userId])
  @@index([status])
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  issuedAt       DateTime @default(now())
  certificateUrl String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectorOrder {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  email          String
  fullName       String
  phone          String
  city           String
  postOffice     String
  orderReference String        @unique
  amount         Int
  gamePrice      Int?
  shippingCost   Int?
  actualShippingCost Int?
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  orderStatus    OrderStatus   @default(NEW)
  trackingNumber String?
  trackingSetAt  DateTime?
  trackingSetById    String?
  trackingSetByName  String?
  trackingSetByEmail String?
  trackingSetByRole  String?
  managerNote    String?
  callMe         Boolean       @default(false)
  trackingHistory ConnectorOrderTrackingLog[]

  @@index([paymentStatus])
  @@index([orderStatus])
}

model ConnectorOrderTrackingLog {
  id            String         @id @default(cuid())
  orderId       String
  order         ConnectorOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  value         String
  changedAt     DateTime       @default(now())
  changedById   String?
  changedByName String?
  changedByEmail String?
  changedByRole String?

  @@index([orderId])
}

model News {
  id        String       @id @default(cuid())
  title     String
  slug      String       @unique
  content   String
  excerpt   String?
  titleEn   String?
  titlePl   String?
  excerptEn String?
  excerptPl String?
  contentEn String?
  contentPl String?
  imageUrl    String?
  category    NewsCategory @default(NEWS)
  published   Boolean      @default(false)
  /// Коли задано — новина схована з вітрини. Використовується і для "паузи", і для відкладеної публікації (coupled з resumeAt).
  suspendedAt DateTime?
  /// Коли задано разом з suspendedAt — новина автоматично повертається на вітрину з цієї дати.
  resumeAt    DateTime?
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User?        @relation(fields: [authorId], references: [id])

  @@index([published, createdAt])
}

model NovaPostDivision {
  id          Int      @id
  externalId  Int      @unique
  name        String
  countryCode String
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  status      String?
  category    String?
  syncedAt    DateTime @default(now())

  @@index([countryCode])
  @@index([countryCode, name])
  @@index([countryCode, city])
}

model NovaPostSyncLog {
  id          String   @id @default(cuid())
  syncedAt    DateTime @default(now())
  totalCount  Int
  status      String
  message     String?
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionPlan {
  MONTHLY
  SIX_MONTHS
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  SENDPULSE
  LOCAL
}

model Bundle {
  id          String         @id @default(cuid())
  title       String
  description String?
  slug        String         @unique
  price       Int
  imageUrl    String?
  published   Boolean        @default(false)
  suspendedAt DateTime?
  resumeAt    DateTime?
  /// Тип пакету: DISCOUNT — стара логіка зі знижкою; FIXED_FREE — N платних + M безкоштовних фіксованих; CHOICE_FREE — N платних + пул безкоштовних (клієнт обирає freeCount)
  type        BundleType     @default(DISCOUNT)
  /// Очікувана кількість платних курсів у пакеті (для валідації UI/checkout)
  paidCount   Int            @default(2)
  /// Кількість безкоштовних, які клієнт отримує при покупці (0 для DISCOUNT)
  freeCount   Int            @default(0)
  /// Позиція у списку (менше = вище). Drag-and-drop reorder в адмінці.
  sortOrder   Int            @default(0)
  /// Режим відображення на публічній /courses: 'solo' — завжди один в ряду (за замовчуванням); 'auto' — групується з іншими тієї самої ширини.
  displayMode String         @default("solo")
  createdAt   DateTime       @default(now())
  courses     BundleCourse[]
  payments    Payment[]

  @@index([sortOrder])
}

model BundleCourse {
  id         String @id @default(cuid())
  bundleId   String
  courseSlug  String
  /// true — курс безкоштовний у цьому пакеті (для FIXED_FREE — видається всім; для CHOICE_FREE — кандидат у пул)
  isFree     Boolean @default(false)
  bundle     Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseSlug])
  @@index([bundleId])
}

enum BundleType {
  DISCOUNT
  FIXED_FREE
  CHOICE_FREE
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  courseId       String?
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  course        Course?   @relation(fields: [courseId], references: [id])

  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NewsCategory {
  NEWS
  ANNOUNCEMENT
  ARTICLE
  EVENT
}

/// Лог усіх платіжних callback-ів (course / bundle / connector).
/// Пишеться ЗАВЖДИ — навіть для invalid signature, retry або idempotent skip.
model PaymentCallbackLog {
  id                 String   @id @default(cuid())
  source             String   // "wayforpay" | "manual" | ...
  kind               String   // "course" | "bundle" | "connector" | "unknown"
  orderReference     String?
  transactionStatus  String?  // Approved / Declined / Expired / InProcessing / ...
  amount             Int?
  currency           String?
  clientEmail        String?
  ip                 String?
  userAgent          String?
  signatureValid     Boolean?
  prevStatus         String?  // статус Payment/ConnectorOrder ДО цього callback
  actionsTaken       String?  // "payment:updated,enrollment:created,sendpulse:sent(2)"
  sendpulseSlugs     String?  // слаги курсів, по яких реально відправлено events
  skipped            Boolean  @default(false)
  skipReason         String?
  rawPayload         Json?
  error              String?
  createdAt          DateTime @default(now())

  @@index([orderReference])
  @@index([createdAt])
  @@index([kind])
}

/// Override-и динамічних полів спеціалістів (ціна, тривалість, кнопка запису, приховування).
/// Базовий контент (імʼя, опис, освіта, сертифікати) лишається у TS-файлах
/// `app/[locale]/consultations/_content/*.ts`. Ключ — slug, що дорівнює slug-у в TS.
model SpecialistOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  price     String?
  duration  String?
  btnLabel  String?
  btnUrl    String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Override ціни курсу для керування з адмінки без деплою.
/// Ключ — slug із `lib/coursesCatalog.ts`. Якщо відповідне поле не null —
/// воно перекриває значення з config.ts/каталогу. Відсутність рядка = повний дефолт.
/// `oldPrice` — стара ціна, що рендериться перекресленою поруч із новою (тільки на
/// детальних сторінках курсів; у списку /courses завжди видно тільки актуальну ціну).
model CoursePriceOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  price     Int?
  oldPrice  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}