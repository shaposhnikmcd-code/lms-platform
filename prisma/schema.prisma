generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime     @default(now())
  role          UserRole     @default(STUDENT)
  accounts      Account[]
  enrollments   Enrollment[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String
  price       Int
  published   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  imageUrl    String?
  enrollments Enrollment[]
  modules     Module[]
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id       String  @id @default(cuid())
  title    String
  order    Int
  moduleId String
  content  String?
  videoUrl String?
  module   Module  @relation(fields: [moduleId], references: [id])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model ConnectorOrder {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Дані покупця
  email          String
  fullName       String
  phone          String

  // Доставка
  city           String
  postOffice     String

  // Оплата
  orderReference String        @unique
  amount         Int
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?

  // Статус обробки менеджером
  orderStatus    OrderStatus   @default(NEW)
  trackingNumber String?
  managerNote    String?
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
