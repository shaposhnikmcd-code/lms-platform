generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                         String                      @id @default(cuid())
  name                       String?
  email                      String                      @unique
  emailVerified              DateTime?
  password                   String?
  image                      String?
  createdAt                  DateTime                    @default(now())
  lastLoginAt                DateTime?
  role                       UserRole                    @default(STUDENT)
  accounts                   Account[]
  enrollments                Enrollment[]
  sessions                   Session[]
  progress                   CourseProgress[]
  lessonProgress             LessonProgress[]
  payments                   Payment[]
  certificates               Certificate[]
  subscriptions              Subscription[]
  yearlyProgramSubscriptions YearlyProgramSubscription[]
  courseTeachers             CourseTeacher[]
  news                       News[]
  passwordResetTokens        PasswordResetToken[]
  auditEvents                UserAuditLog[]              @relation("UserAuditTarget")
  deletedAt                  DateTime?
  deletedById                String?
  deletedByName              String?
  deletedByEmail             String?

  @@index([role])
  @@index([deletedAt])
}

/// Лог подій життєвого циклу акаунтів ADMIN/MANAGER (хто і кого додав/видалив/відновив).
/// Сюди НЕ записуємо buyer-юзерів від платіжних webhook-ів. Подія = один рядок.
model UserAuditLog {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation("UserAuditTarget", fields: [userId], references: [id], onDelete: Cascade)
  eventType   UserAuditEvent
  /// Snapshot стану цільового юзера на момент події (щоб історія була читабельною
  /// навіть якщо юзера потім перейменували / змінили роль).
  targetName  String?
  targetEmail String
  targetRole  UserRole
  /// Хто виконав дію. actorId може бути null якщо подія системна (OAuth-первинний логін).
  actorId     String?
  actorName   String?
  actorEmail  String?
  createdAt   DateTime       @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([eventType])
}

enum UserAuditEvent {
  CREATED
  DELETED
  RESTORED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/// Токен для встановлення/скидання пароля. Покриває два сценарії:
/// - INVITE: адмін створив юзера → лінк "встановіть свій пароль" (TTL 7 днів)
/// - RESET: юзер сам забув пароль → лінк "створіть новий пароль" (TTL 1 година)
/// tokenHash — SHA-256 сирого токена, сирий токен живе лише в листі.
/// usedAt — single-use guard.
model PasswordResetToken {
  id        String                    @id @default(cuid())
  userId    String
  tokenHash String                    @unique
  purpose   PasswordResetTokenPurpose @default(RESET)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                  @default(now())
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum PasswordResetTokenPurpose {
  INVITE
  RESET
}

model Course {
  id                String           @id @default(cuid())
  title             String
  description       String
  price             Int
  published         Boolean          @default(false)
  createdAt         DateTime         @default(now())
  imageUrl          String?
  slug              String?          @unique
  /// ID курсу в SendPulse (Education API). Заповнюємо з URL курсу в кабінеті SP.
  /// Потрібно для auto-видачі сертифікатів через cron: без цього курс пропускається
  /// (сертифікат можна видати вручну з адмінки).
  sendpulseCourseId Int?
  enrollments       Enrollment[]
  modules           Module[]
  progress          CourseProgress[]
  payments          Payment[]
  certificates      Certificate[]
  courseTeachers    CourseTeacher[]
  promoCodes        PromoCode[]
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id             String           @id @default(cuid())
  title          String
  order          Int
  moduleId       String
  content        String?
  videoUrl       String?
  videoProvider  VideoProvider    @default(YOUTUBE)
  videoId        String?
  duration       Int?
  isFree         Boolean          @default(false)
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress[]
  lessonProgress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  watchedAt   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Прогрес з SendPulse Education API (0-100). Оновлюється щоденним cron-ом
  /// `/api/cron/course-certificates`. NULL = ще не перевіряли або курс без sendpulseCourseId.
  spProgressPercent   Int?
  spProgressCheckedAt DateTime?

  @@unique([userId, courseId])
}

model CourseProgress {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  lastLessonId    String?
  progressPercent Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lastLesson      Lesson?   @relation(fields: [lastLessonId], references: [id])

  @@unique([userId, courseId])
}

model Payment {
  id                          String                     @id @default(cuid())
  userId                      String
  courseId                    String?
  bundleId                    String?
  orderReference              String                     @unique
  amount                      Int
  currency                    String                     @default("UAH")
  status                      PaymentStatus              @default(PENDING)
  /// Для CHOICE_FREE bundle-ів: слаги курсів, які клієнт обрав як безкоштовні
  freeSlugs                   String[]                   @default([])
  createdAt                   DateTime                   @default(now())
  paidAt                      DateTime?
  /// Якщо платіж є частиною підписки річної програми — лінк сюди.
  /// Один Payment = один щомісячний charge; для YEARLY plan створюється один Payment на рік.
  yearlyProgramSubscriptionId String?
  /// Джерело продажу (UIMP за замовчуванням, TETYANA — з персонального сайту Тетяни)
  source                      SaleSource                 @default(UIMP)
  /// orderReference з зовнішньої системи (для продажів з інших сайтів, напр. tetyana-website)
  externalRef                 String?
  /// Provisioning tracking — для course/bundle:
  /// `enrollmentsCompletedAt` set після того, як ВСІ очікувані Enrollment-и створені.
  /// `sendpulseSentAt` set після того, як SendPulse event надіслано для всіх slug-ів.
  /// `provisionError` — останнє повідомлення помилки якщо провіжинінг впав.
  /// Reconciliation cron (`/api/cron/reconcile-payments`) знаходить PAID payments з
  /// NULL у будь-якому з 2-х timestamps і догенеровує відсутнє. Сам callback ставить ці
  /// поля у success-кейсі, а на помилці — лишає NULL і записує `provisionError`.
  enrollmentsCompletedAt      DateTime?
  sendpulseSentAt             DateTime?
  provisionError              String?
  yearlyProgramSubscription   YearlyProgramSubscription? @relation("YearlyProgramPayments", fields: [yearlyProgramSubscriptionId], references: [id])
  user                        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                      Course?                    @relation(fields: [courseId], references: [id])
  bundle                      Bundle?                    @relation(fields: [bundleId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([yearlyProgramSubscriptionId])
  @@index([status, createdAt])
  @@index([bundleId])
  @@index([courseId])
  @@index([createdAt])
  @@index([source])
  @@index([status, enrollmentsCompletedAt, sendpulseSentAt])
}

/// Сертифікати UIMP — два типи:
/// 1) COURSE — видається автоматично після завершення конкретного курсу на SendPulse.
/// 2) YEARLY_PROGRAM — видається вручну адміном після завершення річної програми,
///    з категорією LISTENER (Слухач) або PRACTICAL (Практична участь).
///
/// Всі ключові поля друкуються на PDF зі snapshot-ів (recipientName, courseName,
/// issueYear), щоб перейменування курсу чи зміна імені юзера не впливали на
/// вже виданий документ. PDF регенерується з БД on-demand за verificationToken.
model Certificate {
  id                String          @id @default(cuid())
  /// Людино-читабельний номер для друку: UIMP-COURSE-2026-00042 / UIMP-YEAR-2026-00007
  certNumber        String          @unique
  /// Непередбачуваний token для публічної верифікації /certificate/{token}. 32 символи nanoid.
  verificationToken String          @unique
  type              CertificateType
  /// Тільки для YEARLY_PROGRAM: LISTENER або PRACTICAL. null для COURSE.
  category          CertCategory?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Для COURSE: id курсу в нашій БД. Для YEARLY — null.
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id])

  /// Для YEARLY_PROGRAM: лінк на підписку, за якою виданий серт.
  subscriptionId String?
  subscription   YearlyProgramSubscription? @relation(fields: [subscriptionId], references: [id])

  /// Snapshot recipient name (що буде надруковано) — editable у білдері перед видачею.
  recipientName  String
  recipientEmail String
  /// Snapshot назви курсу/теми на момент видачі (друкується як subject):
  /// COURSE — назва курсу, SUPERVISION — тема супервізії, YEARLY_PROGRAM — null.
  courseName     String?
  /// Тільки для SUPERVISION: дата проведення супервізійного заняття (друкується на серті).
  /// null означає, що менеджер не вказав дату (опційне поле).
  supervisionDate DateTime?
  /// Тільки для SUPERVISION: тривалість заняття в годинах (Float, дозволяє 1.5/2.5 тощо).
  /// null = менеджер не вказав. Друкується поряд з датою у body сертифіката.
  supervisionHours Float?
  /// Рік видачі — друкується на сертифікаті (замість baked-in "2026" в JPG).
  issueYear      Int

  issuedAt       DateTime @default(now())
  /// null = згенеровано системою (cron); заповнене = видано вручну адміном.
  issuedByUserId String?
  issuedByName   String?
  issuedByEmail  String?
  /// true = видано через білдер адміном; false = автовидача з крона.
  issuedManually Boolean  @default(false)

  /// SHA-256 згенерованого PDF — для integrity checks (audit).
  pdfHash String?

  emailStatus      CertEmailStatus @default(PENDING)
  emailSentAt      DateTime?
  emailMessageId   String?
  emailError       String?
  /// From-адреса, з якої реально пішов лист (snapshot RESEND_FROM_EMAIL на момент відправки).
  /// null = ще не відправлявся, або відправлявся до того як це поле зʼявилося.
  emailFromAddress String?

  revoked         Boolean   @default(false)
  revokedAt       DateTime?
  revokedByUserId String?
  revokedByName   String?
  revokedReason   String?

  events CertificateEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Унікальність "активного" сертифіката — реалізована як **partial unique index** на рівні
  /// Postgres (`WHERE revoked = false`) — див. міграцію `20260427120000_cert_partial_unique`.
  /// Це дозволяє існувати кільком записам на (userId,type,courseId) якщо всі окрім одного
  /// відкликані (потрібно для перевидачі сертифіката після відклику). Prisma 5 не підтримує
  /// partial unique у DSL, тому `@@unique` тут НЕ ставимо — enforcement лишається в БД.
  @@index([type, issuedAt])
  @@index([subscriptionId])
  @@index([issuedByUserId])
  @@index([emailStatus])
  @@index([revoked])
}

/// Append-only аудит лог дій над сертифікатами — видно в адмінці ("Історія").
model CertificateEvent {
  id            String      @id @default(cuid())
  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  /// Хто ініціював подію: adminId, або null якщо system (cron / auto).
  actorId       String?
  actorName     String?
  actorEmail    String?
  /// GENERATED | SENT | RESENT | REVOKED | DOWNLOADED | VIEWED | EMAIL_FAILED
  action        String
  message       String?
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([certificateId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

enum CertificateType {
  COURSE
  YEARLY_PROGRAM
  /// Сертифікат за участь в супервізійному занятті — видається менеджерами вручну.
  /// Не пов'язаний з оплатою/курсом/підпискою; не потрапляє у вкладку "Помилки".
  SUPERVISION
}

enum CertCategory {
  LISTENER // Слухач — нижча категорія
  PRACTICAL // Практична участь — вища категорія
}

enum CertEmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectorOrder {
  id                 String                      @id @default(cuid())
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  email              String
  fullName           String
  phone              String
  city               String
  postOffice         String
  orderReference     String                      @unique
  amount             Int
  gamePrice          Int?
  shippingCost       Int?
  actualShippingCost Int?
  paymentStatus      PaymentStatus               @default(PENDING)
  paidAt             DateTime?
  orderStatus        OrderStatus                 @default(NEW)
  trackingNumber     String?
  trackingSetAt      DateTime?
  trackingSetById    String?
  trackingSetByName  String?
  trackingSetByEmail String?
  trackingSetByRole  String?
  managerNote        String?
  callMe             Boolean                     @default(false)
  /// Джерело продажу (UIMP за замовчуванням, TETYANA — з персонального сайту Тетяни)
  source             SaleSource                  @default(UIMP)
  /// orderReference з зовнішньої системи
  externalRef        String?
  trackingHistory    ConnectorOrderTrackingLog[]

  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([source])
}

model ConnectorOrderTrackingLog {
  id             String         @id @default(cuid())
  orderId        String
  order          ConnectorOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  value          String
  changedAt      DateTime       @default(now())
  changedById    String?
  changedByName  String?
  changedByEmail String?
  changedByRole  String?

  @@index([orderId])
}

/// Shared-DB: належить tetyana-website (LMS таблицю не використовує).
/// Оголошена тут лише для того, щоб LMS-міграції не видалили її як drift.
model BookingOrder {
  id               String        @id @default(cuid())
  orderReference   String        @unique
  service          String
  method           String
  status           PaymentStatus @default(PENDING)
  amount           Int
  currency         String
  originalAmount   Int
  originalCurrency String
  promoCode        String?
  promoAmount      Int?
  promoCurrency    String?
  clientEmail      String?
  clientName       String?
  clientPhone      String?
  isAdminTest      Boolean       @default(false)
  stripeSessionId  String?
  createdAt        DateTime      @default(now())
  paidAt           DateTime?
  failedAt         DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([service])
  @@index([method])
  @@index([status, createdAt])
}

/// Сторінка-список новин /news. Зберігає блоки (heading/text/image/newsCard тощо),
/// якими користувач у білдері формує саму сторінку. Singleton key="default";
/// підтримуємо key для майбутніх категорійних landing-сторінок.
model NewsPage {
  id          String   @id @default(cuid())
  key         String   @unique @default("default")
  /// JSON-масив блоків у тому ж форматі що й News.content (lib/news/render).
  content     String
  contentEn   String?
  contentPl   String?
  /// Колір фону сторінки (за замовчуванням — поточний gray-50).
  pageBgColor String?
  /// Чи опублікована сторінка на /news. false (default) → /news показує empty state,
  /// незалежно від наявності блоків. Адмін активує через кнопку на /dashboard/admin/news.
  published   Boolean  @default(false)
  /// Staged-копія для запланованого оновлення сторінки. Менеджер редагує "Наступну сторінку"
  /// у білдері /page-builder/next і виставляє nextPublishAt — у той момент cron копіює
  /// next* → live (content/contentEn/contentPl/pageBgColor) і чистить next* поля.
  /// null означає що staged-версії немає (єдина live-сторінка).
  nextContent     String?
  nextContentEn   String?
  nextContentPl   String?
  nextPageBgColor String?
  nextPublishAt   DateTime?
  /// Хто і коли востаннє редагував staged. Допомагає у адмінці показати "редаговано Х годин тому".
  nextUpdatedAt   DateTime?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([nextPublishAt])
}

model News {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  titleEn     String?
  titlePl     String?
  excerptEn   String?
  excerptPl   String?
  contentEn   String?
  contentPl   String?
  /// Окремий JSON-білдер превʼю-картки для сторінки /news. null = використовується дефолтний
  /// рендер (cover + title + excerpt + date). Якщо задано — повна свобода компонування через
  /// білдер /dashboard/admin/news/[id]/preview.
  previewContent String?
  previewContentEn String?
  previewContentPl String?
  imageUrl    String?
  /// Колір фону внутрішньої "сторінки новини" (білий контейнер з блоками). null = дефолтний білий.
  pageBgColor String?
  category    NewsCategory @default(NEWS)
  published   Boolean      @default(false)
  /// Коли задано — новина схована з вітрини. Використовується і для "паузи", і для відкладеної публікації (coupled з resumeAt).
  suspendedAt DateTime?
  /// Коли задано разом з suspendedAt — новина автоматично повертається на вітрину з цієї дати.
  resumeAt    DateTime?
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User?        @relation(fields: [authorId], references: [id])

  @@index([published, createdAt])
}

model NovaPostDivision {
  id          Int      @id
  externalId  Int      @unique
  name        String
  countryCode String
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  status      String?
  category    String?
  syncedAt    DateTime @default(now())

  @@index([countryCode])
  @@index([countryCode, name])
  @@index([countryCode, city])
}

model NovaPostSyncLog {
  id         String   @id @default(cuid())
  syncedAt   DateTime @default(now())
  totalCount Int
  status     String
  message    String?
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SaleSource {
  UIMP
  TETYANA
}

enum SubscriptionPlan {
  MONTHLY
  SIX_MONTHS
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  SENDPULSE
  LOCAL
}

model Bundle {
  id          String         @id @default(cuid())
  title       String
  titleEn     String?
  titlePl     String?
  description String?
  slug        String         @unique
  price       Int
  imageUrl    String?
  published   Boolean        @default(false)
  suspendedAt DateTime?
  resumeAt    DateTime?
  /// Тип пакету: DISCOUNT — стара логіка зі знижкою; FIXED_FREE — N платних + M безкоштовних фіксованих; CHOICE_FREE — N платних + пул безкоштовних (клієнт обирає freeCount)
  type        BundleType     @default(DISCOUNT)
  /// Очікувана кількість платних курсів у пакеті (для валідації UI/checkout)
  paidCount   Int            @default(2)
  /// Кількість безкоштовних, які клієнт отримує при покупці (0 для DISCOUNT)
  freeCount   Int            @default(0)
  /// Позиція у списку (менше = вище). Drag-and-drop reorder в адмінці.
  sortOrder   Int            @default(0)
  /// Номер ряду на публічній /courses (bundles з однаковим rowGroup ідуть у тому ж ряду). null = ще не згруповано, fallback до pack-by-2.
  rowGroup    Int?
  /// Режим відображення на публічній /courses: 'solo' — завжди один в ряду (за замовчуванням); 'auto' — групується з іншими тієї самої ширини.
  displayMode String         @default("solo")
  createdAt   DateTime       @default(now())
  courses     BundleCourse[]
  payments    Payment[]

  @@index([sortOrder])
  /// Прискорює основний публічний запит /courses: where published=true AND suspendedAt IS NULL ORDER BY sortOrder, createdAt
  @@index([published, suspendedAt, sortOrder, createdAt])
  /// Прискорює auto-resume cron: where suspendedAt IS NOT NULL AND resumeAt <= now()
  @@index([suspendedAt, resumeAt])
}

model BundleCourse {
  id         String  @id @default(cuid())
  bundleId   String
  courseSlug String
  /// true — курс безкоштовний у цьому пакеті (для FIXED_FREE — видається всім; для CHOICE_FREE — кандидат у пул)
  isFree     Boolean @default(false)
  bundle     Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseSlug])
  @@index([bundleId])
}

enum BundleType {
  DISCOUNT
  FIXED_FREE
  CHOICE_FREE
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  courseId      String?
  maxUses       Int?
  usedCount     Int          @default(0)
  active        Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  course        Course?      @relation(fields: [courseId], references: [id])

  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NewsCategory {
  NEWS
  ANNOUNCEMENT
  ARTICLE
  EVENT
}

/// Лог усіх платіжних callback-ів (course / bundle / connector).
/// Пишеться ЗАВЖДИ — навіть для invalid signature, retry або idempotent skip.
model PaymentCallbackLog {
  id                String   @id @default(cuid())
  source            String // "wayforpay" | "manual" | ...
  kind              String // "course" | "bundle" | "connector" | "unknown"
  orderReference    String?
  transactionStatus String? // Approved / Declined / Expired / InProcessing / ...
  amount            Int?
  currency          String?
  clientEmail       String?
  ip                String?
  userAgent         String?
  signatureValid    Boolean?
  prevStatus        String? // статус Payment/ConnectorOrder ДО цього callback
  actionsTaken      String? // "payment:updated,enrollment:created,sendpulse:sent(2)"
  sendpulseSlugs    String? // слаги курсів, по яких реально відправлено events
  skipped           Boolean  @default(false)
  skipReason        String?
  rawPayload        Json?
  error             String?
  createdAt         DateTime @default(now())

  @@index([orderReference])
  @@index([createdAt])
  @@index([kind])
}

/// Підписка на Річну програму (навчальна програма на платформі SendPulse).
/// YEARLY = одна оплата, доступ на 1 рік. MONTHLY = щомісячне авто-списання через WayForPay
/// regularApi (WFP-managed schedule), при кожному успішному charge expiresAt продовжується
/// на +30 днів. Доступ до SendPulse курсу відкривається подією (SENDPULSE_EVENT_URL) і
/// закривається через Education API (DELETE /students/{studentId}/{courseId}).
model YearlyProgramSubscription {
  id              String                          @id @default(cuid())
  userId          String
  user            User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            YearlyProgramPlan
  status          YearlyProgramSubscriptionStatus @default(PENDING)
  /// Для MONTHLY плану: true — автосписання ввімкнено (WFP-managed regular schedule, 9 платежів);
  /// false — разова оплата за 1 місяць без рекурентних списань.
  /// Для YEARLY плану завжди false (у річної немає рекурентних списань).
  /// Це source-of-truth для cron, який вирішує MANUAL vs CYCLICAL reminder flow.
  autoRenew       Boolean                         @default(false)
  startDate       DateTime?
  /// Для YEARLY = startDate + 1 рік. Для MONTHLY = останній успішний charge + 30 днів.
  expiresAt       DateTime?
  cancelledAt     DateTime?
  cancelledBy     String? // "user" | "admin" | "system"
  cancelledReason String?

  /// Опційно: orderReference запису в regularApi (якщо колись перейдемо на server-managed schedule).
  wfpRegularRef       String?
  lastPaymentAt       DateTime?
  lastChargeAttemptAt DateTime?
  lastChargeError     String?
  failedChargeCount   Int       @default(0)

  /// SendPulse Education API — studentId (integer) для виклику DELETE /students/{id}/{courseId}.
  /// Лук-апимо через POST /students/by-course/{courseId} по email після першої оплати.
  sendpulseStudentId      Int?
  sendpulseAccessOpenedAt DateTime?
  sendpulseAccessClosedAt DateTime?

  /// Прогрес у курсі "Річна програма" (SENDPULSE_YEARLY_COURSE_ID).
  /// Оновлюється щоденним cron-ом `/api/cron/yearly-subscriptions`.
  spProgressPercent   Int?
  spProgressCheckedAt DateTime?

  /// Момент переходу ACTIVE→GRACE + розрахована межа закінчення grace-періоду.
  /// expiresAt + graceDays НЕ використовуємо як фільтр expireGraceSubscriptions, бо при
  /// пропущеному cron-добу підписка потрапляє в GRACE з expiresAt глибоко в минулому —
  /// це б миттєво expire-ало її. Ми фіксуємо, коли саме GRACE почалось, і експайраємо
  /// лише коли `gracePeriodEndsAt < now`.
  graceStartedAt    DateTime?
  gracePeriodEndsAt DateTime?

  /// Нагадування про закінчення / grace. Розклад адаптивний за `graceDays`:
  ///   start    — день +1 від expiresAt (завжди)
  ///   mid      — приблизно середина grace-періоду (тільки якщо graceDays ≥ 5)
  ///   last     — за 1 день до закриття (тільки якщо graceDays ≥ 3)
  ///   closed   — у день закриття (завжди)
  /// MANUAL і CYCLICAL шари — окремі шаблони з однаковим розкладом.
  reminderSent3d         Boolean @default(false) /// manual: 3 дні до закінчення
  reminderSentExpired    Boolean @default(false) /// shared: accessClosed у день закриття
  reminderSentOnExpiry   Boolean @default(false) /// manual: у день закінчення
  reminderSentGraceStart Boolean @default(false) /// manual+cyclical: день +1 (grace стартував)
  reminderSentGraceMid   Boolean @default(false) /// manual+cyclical: середина пільгового періоду (graceDays ≥ 5)
  reminderSentGraceLast  Boolean @default(false) /// manual+cyclical: за 1 день до закриття (graceDays ≥ 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Запуск Річної програми (cohort), до якого належить ця підписка.
  /// Усі нові оплати потрапляють у поточний cohort (`isCurrent=true`). Менеджер
  /// може перенести підписку в наступний cohort вручну до моменту запуску.
  /// nullable для зворотної сумісності з підписками, створеними до cohort-системи.
  cohortId String?
  cohort   YearlyProgramCohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  /// Manual-add: підписка створена через invite-link від менеджера для студента, який
  /// не встиг купити Річну програму до запуску cohort-у. manuallyAddedAt = момент callback-у
  /// (коли студент оплатив). manuallyAddedBy = email менеджера, що згенерував invite.
  /// У адмінці така підписка виділяється пілюлею "✋ Додано вручну" + має кнопку
  /// "🎯 Екстра Запуск" для індивідуального відкриття SendPulse доступу та welcome-листа.
  manuallyAddedAt DateTime?
  manuallyAddedBy String?

  /// Дані з форми оплати (нові поля 2026-05-04).
  /// country — ISO-3166-1 alpha-2 код країни проживання (UA, PL, DE...). null для legacy.
  /// telegramUsername — нормалізований TG-handle з префіксом @ (напр. "@ihor"). null якщо не вказано.
  /// telegramInviteLink — згенероване через Bot API одноразове invite-посилання у канал/групу
  /// Річної програми. Створюється автоматично при оплаті (якщо auto_add=ON у settings) або
  /// вручну з адмінки. member_limit=1, expire_date=+30д.
  /// telegramInvitedAt — момент успішної генерації invite-link.
  /// telegramInviteError — текст помилки Bot API при невдалій спробі (показується в адмінці).
  /// telegramJoinedAt — момент, коли клієнт реально приєднався в канал/групу
  /// (webhook ставить це після `approveChatJoinRequest` або при `chat_member` transition
  /// from left/restricted/kicked → member).
  /// telegramLeftAt — момент, коли клієнт вийшов із каналу (Leave) або був виключений
  /// (Kick/Ban). Webhook слухає `chat_member` updates і ставить це при transition
  /// member → left/kicked/restricted. При повторному приєднанні `telegramJoinedAt`
  /// оновлюється, `telegramLeftAt` скидається в null.
  /// telegramTgUserId — Telegram user_id (BigInt — id-шники TG до 10+ цифр).
  /// Зберігається при першому approve або при rejoin через chat_member-handler,
  /// і дозволяє швидко (без invite-link match-у) знаходити підписку на майбутні
  /// chat_member updates (leave/rejoin). Null = ще не приєднувався або pre-migration row.
  country             String?
  telegramUsername    String?
  telegramInviteLink  String?
  telegramInvitedAt   DateTime?
  telegramInviteError String?
  telegramJoinedAt    DateTime?
  telegramLeftAt      DateTime?
  telegramTgUserId    BigInt?

  payments     Payment[]                        @relation("YearlyProgramPayments")
  events       YearlyProgramSubscriptionEvent[]
  certificates Certificate[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([status, expiresAt])
  @@index([plan, status, expiresAt])
  @@index([cohortId])
  @@index([telegramTgUserId])
  @@index([manuallyAddedAt])
}

/// Лог важливих подій підписки — видно в адмінці для прозорості й дебагу.
model YearlyProgramSubscriptionEvent {
  id             String                    @id @default(cuid())
  subscriptionId String
  subscription   YearlyProgramSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  /// "created" | "renewed" | "charge_attempt" | "charge_success" | "charge_failed"
  /// | "access_opened" | "access_closed" | "reminder_3d" | "reminder_1d" | "reminder_expired"
  /// | "cancelled" | "reactivated" | "admin_action"
  /// | "autorenew_upgraded" | "autorenew_downgraded"
  type           String
  message        String?
  metadata       Json?
  createdAt      DateTime                  @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
  @@index([type])
}

enum YearlyProgramPlan {
  YEARLY
  MONTHLY
}

/// "Запуск" Річної програми — навчальна когорта з фіксованими датами старту та завершення.
/// Менеджер створює cohort заздалегідь (наприклад, "Річна програма 2026" зі стартом 01.09.2026).
/// Усі нові оплати автоматично потрапляють у поточний (`isCurrent=true`) cohort.
/// Доступ до SendPulse і email-розсилка стартують у момент запуску — менеджер тисне
/// "🚀 Запустити програму", фіксується `launchedAt`, відкривається SendPulse усім оплаченим,
/// розсилається welcome-лист. Розсилку можна виконати окремо ("✉️ Запустити розсилку")
/// — миттєво або за запланованою датою (`emailScheduledFor` обробляється cron-ом).
model YearlyProgramCohort {
  id   String @id @default(cuid())
  /// Назва, що показується в адмінці й у листах. Default: `Річна програма {рік startDate}`.
  name String

  /// Планована дата старту програми (доступ у SendPulse активний з цієї дати).
  startDate DateTime
  /// Планована дата завершення програми (доступ закривається після цієї дати).
  endDate   DateTime

  /// Момент, коли менеджер натиснув "🚀 Запустити програму" — відкриває SendPulse усім
  /// оплаченим підпискам у cohort, перераховує доступ. null = ще не запущено.
  launchedAt DateTime?

  /// Запланований запуск. Менеджер може запустити негайно (launchedAt=now) АБО
  /// запланувати на майбутнє (launchScheduledFor=future, launchedAt=null). Cron
  /// yearly-subscriptions щодоби перевіряє і виконує запуск коли час прийшов.
  /// Після фактичного запуску launchScheduledFor очищається, launchedAt = реальний момент.
  launchScheduledFor DateTime?

  /// Розклад welcome-розсилки. emailScheduledFor у майбутньому — cron обробить пізніше;
  /// emailScheduledFor у минулому без emailSentAt — ще не оброблено (буде у наступному cron-tick).
  emailScheduledFor DateTime?
  emailSentAt       DateTime?

  /// Шаблон welcome-листа. Підтримує плейсхолдери {{name}}, {{startDate}}, {{endDate}}, {{cohortName}}.
  /// null → fallback на дефолтний шаблон з lib/yearlyProgramCohort.ts.
  launchEmailSubject String?
  launchEmailBody    String?

  /// Поточний cohort — той, у який потрапляють нові оплати. Тільки один cohort
  /// може мати isCurrent=true (DB constraint через partial unique index).
  isCurrent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions YearlyProgramSubscription[]

  @@index([startDate])
  @@index([isCurrent])
}

enum YearlyProgramSubscriptionStatus {
  PENDING // створено, перша оплата ще не пройшла
  ACTIVE // доступ відкритий, expiresAt у майбутньому
  GRACE // expiresAt у минулому, але в межах grace-періоду (1 день)
  EXPIRED // доступ закрито, списання припинено
  CANCELLED // юзер/адмін скасував регулярку
  ARCHIVED // адмін заархівував (доступ SendPulse закритий, tech-поля очищені, reopen заблокований)
}

/// Override-и динамічних полів спеціалістів (ціна, тривалість, кнопка запису, приховування).
/// Базовий контент (імʼя, опис, освіта, сертифікати) лишається у TS-файлах
/// `app/[locale]/consultations/_content/*.ts`. Ключ — slug, що дорівнює slug-у в TS.
model SpecialistOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  price     String?
  duration  String?
  btnLabel  String?
  btnUrl    String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Override ціни курсу для керування з адмінки без деплою.
/// Ключ — slug із `lib/coursesCatalog.ts`. Якщо відповідне поле не null —
/// воно перекриває значення з config.ts/каталогу. Відсутність рядка = повний дефолт.
/// `oldPrice` — стара ціна, що рендериться перекресленою поруч із новою (тільки на
/// детальних сторінках курсів; у списку /courses завжди видно тільки актуальну ціну).
model CoursePriceOverride {
  id              String    @id @default(cuid())
  slug            String    @unique
  price           Int?
  oldPrice        Int?
  /// Per-course промокоди (до 2 на курс). `code` зберігається в UPPER-case.
  /// На відміну від глобальної моделі `PromoCode`, тут код може повторюватись між курсами,
  /// і ціна — фіксована (не percentage/fixed-discount).
  ///
  /// Опційне вікно дії промокоду: `startsAt` — коли стає активним (null = одразу),
  /// `expiresAt` — коли стає неактивним (null = безстроково). Перевірка робиться
  /// в `lib/paymentPricing.ts:applyPromoServerSide` і `/api/promo/validate`.
  promo1Code      String?
  promo1Price     Int?
  promo1StartsAt  DateTime?
  promo1ExpiresAt DateTime?
  promo2Code      String?
  promo2Price     Int?
  promo2StartsAt  DateTime?
  promo2ExpiresAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Лог змін на сторінці адмін → Курси (ціни + промокоди + SP course ID).
/// Пишеться при кожному PATCH/DELETE в `/api/admin/courses/[slug]`.
/// `changes` — JSON об'єкт `{ fieldName: { old, new } }` тільки для полів, що реально змінились.
model CoursePriceAuditLog {
  id        String   @id @default(cuid())
  slug      String
  userId    String?
  userEmail String?
  userName  String?
  action    String // "update" | "reset"
  changes   Json
  createdAt DateTime @default(now())

  @@index([slug, createdAt])
  @@index([createdAt])
}

/// Промокоди по категоріях продуктів (bundle, connector). На відміну від
/// `CoursePriceOverride`, тут НЕ керуємо ціною продукту — тільки фіксованою
/// ціною за промокодом. Один код на всю категорію (будь-який пакет / гра Конектор).
/// `category` приймає значення "bundle" або "connector".
model CategoryPromoOverride {
  id              String    @id @default(cuid())
  category        String    @unique
  promo1Code      String?
  promo1Price     Int?
  promo1StartsAt  DateTime?
  promo1ExpiresAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Generic key-value store для app-рівневих налаштувань, які треба змінювати
/// runtime без redeploy. Перший споживач — `yearlyGraceDays` (тривалість grace
/// періоду Річної програми у днях). Fallback на дефолт із коду, якщо запис відсутній.
model AppSetting {
  key       String   @id
  value     Int
  updatedAt DateTime @updatedAt
}

/// Singleton-конфіг Telegram-каналу/групи Річної програми. Менеджер вводить chatId
/// (numeric -100... або @username) у адмінці, система резолвить + валідує через
/// Bot API getChat (бот має бути доданий адміном з правом invite users), зберігає
/// chatTitle/chatType для UI-відображення.
/// autoAdd — чи генерувати invite-link автоматично при оплаті Річної програми.
/// Якщо false — менеджер натискає "Надіслати TG-запрошення" вручну в експандованій
/// панелі підписки.
model YearlyProgramTelegramSetting {
  id        String   @id @default("singleton")
  /// Зберігається в нормалізованому вигляді: numeric "-100..." або "@username".
  chatId    String?
  /// Friendly-title з getChat (показується в адмінці після успішної валідації).
  chatTitle String?
  /// "channel" | "supergroup" | "group" — повертає Bot API.
  chatType  String?
  /// Якщо true — на кожну успішну оплату Річної програми callback автоматично
  /// генерує одноразовий invite-link і додає його до welcome-листа.
  autoAdd   Boolean  @default(false)
  /// Якщо true — invite-посилання створюються з `creates_join_request=true`
  /// (без member_limit, бо API їх не дозволяє разом). Канал/група має бути в
  /// режимі "Заявки на вступ" (Telegram → Адмін → Запрошення → Підтвердження).
  /// Webhook `/api/telegram/yearly-program-webhook` автоматично approve-ить
  /// заявки від клієнтів Річної (за збігом invite_link із підпискою) і
  /// decline-ить решту.
  joinRequestMode Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/// Singleton-конфіг сторінки `/yearly-program` (Річна програма), редагований
/// з адмінки без деплою. Завжди один рядок з id="singleton".
/// Якщо поле = null → використовується дефолт із коду
/// (`lib/yearlyProgramSettings.ts` DEFAULTS).
model YearlyProgramSetting {
  id               String   @id @default("singleton")
  yearlyPrice      Int?
  monthlyPrice     Int?
  btnLabel         String?
  priceNote        String?
  duration         String?
  registrationOpen Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

/// Менеджери, відповідальні за обробку замовлень гри «Конектор».
/// Кожен запис — окрема людина: можна задати лише email, лише Telegram chat_id, або обидва.
/// Якщо `enabled = false` — повідомлення не йдуть.
/// `notifyOnNew` — повідомлення про нову заявку (PENDING).
/// `notifyOnPaid` — повідомлення про успішну оплату.
model KonektorManager {
  id              String   @id @default(cuid())
  /// Людське ім'я для адмінки (наприклад "Тетяна / основна").
  label           String
  email           String?
  /// Numeric chat_id (отриманий через бот /start). Підтримує і особисті, і групові.
  telegramChatId  String?
  /// Per-channel вимикачі. Дозволяють тимчасово відключити email або Telegram
  /// без видалення значення. Якщо канал false — повідомлення не йде, навіть якщо поле заповнене.
  emailEnabled    Boolean  @default(true)
  telegramEnabled Boolean  @default(true)
  enabled         Boolean  @default(true)
  notifyOnNew     Boolean  @default(true)
  notifyOnPaid    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
}

/// Шаблони транзакційних листів, які можна редагувати з адмінки без деплою.
/// `templateKey` — стабільний ідентифікатор (welcome, plan-changed-upgrade, receipt-autopay, ...).
/// `subject` і `bodyHtml` містять placeholder-и виду `{name}`, `{plan}`, які підставляються
/// у момент відправки. Якщо запис відсутній — fallback на дефолт із коду
/// (`lib/emailTemplates/paymentDefaults.ts`). Це дозволяє коду продовжувати працювати
/// навіть якщо менеджер ще не зайшов в адмінку.
model EmailTemplate {
  templateKey String   @id
  subject     String
  bodyHtml    String   @db.Text
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}
