generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                         String                      @id @default(cuid())
  name                       String?
  email                      String                      @unique
  emailVerified              DateTime?
  password                   String?
  image                      String?
  createdAt                  DateTime                    @default(now())
  lastLoginAt                DateTime?
  role                       UserRole                    @default(STUDENT)
  accounts                   Account[]
  enrollments                Enrollment[]
  sessions                   Session[]
  progress                   CourseProgress[]
  lessonProgress             LessonProgress[]
  payments                   Payment[]
  certificates               Certificate[]
  subscriptions              Subscription[]
  yearlyProgramSubscriptions YearlyProgramSubscription[]
  courseTeachers             CourseTeacher[]
  news                       News[]
  passwordResetTokens        PasswordResetToken[]
  deletedAt                  DateTime?
  deletedById                String?
  deletedByName              String?
  deletedByEmail             String?

  @@index([role])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/// Токен для встановлення/скидання пароля. Покриває два сценарії:
/// - INVITE: адмін створив юзера → лінк "встановіть свій пароль" (TTL 7 днів)
/// - RESET: юзер сам забув пароль → лінк "створіть новий пароль" (TTL 1 година)
/// tokenHash — SHA-256 сирого токена, сирий токен живе лише в листі.
/// usedAt — single-use guard.
model PasswordResetToken {
  id        String                    @id @default(cuid())
  userId    String
  tokenHash String                    @unique
  purpose   PasswordResetTokenPurpose @default(RESET)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                  @default(now())
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum PasswordResetTokenPurpose {
  INVITE
  RESET
}

model Course {
  id             String           @id @default(cuid())
  title          String
  description    String
  price          Int
  published      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  imageUrl       String?
  slug           String?          @unique
  /// ID курсу в SendPulse (Education API). Заповнюємо з URL курсу в кабінеті SP.
  /// Потрібно для auto-видачі сертифікатів через cron: без цього курс пропускається
  /// (сертифікат можна видати вручну з адмінки).
  sendpulseCourseId Int?
  enrollments    Enrollment[]
  modules        Module[]
  progress       CourseProgress[]
  payments       Payment[]
  certificates   Certificate[]
  courseTeachers CourseTeacher[]
  promoCodes     PromoCode[]
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id             String           @id @default(cuid())
  title          String
  order          Int
  moduleId       String
  content        String?
  videoUrl       String?
  videoProvider  VideoProvider    @default(YOUTUBE)
  videoId        String?
  duration       Int?
  isFree         Boolean          @default(false)
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress[]
  lessonProgress LessonProgress[]

  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  watchedAt   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Прогрес з SendPulse Education API (0-100). Оновлюється щоденним cron-ом
  /// `/api/cron/course-certificates`. NULL = ще не перевіряли або курс без sendpulseCourseId.
  spProgressPercent   Int?
  spProgressCheckedAt DateTime?

  @@unique([userId, courseId])
}

model CourseProgress {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  lastLessonId    String?
  progressPercent Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lastLesson      Lesson?   @relation(fields: [lastLessonId], references: [id])

  @@unique([userId, courseId])
}

model Payment {
  id                          String                     @id @default(cuid())
  userId                      String
  courseId                    String?
  bundleId                    String?
  orderReference              String                     @unique
  amount                      Int
  currency                    String                     @default("UAH")
  status                      PaymentStatus              @default(PENDING)
  /// Для CHOICE_FREE bundle-ів: слаги курсів, які клієнт обрав як безкоштовні
  freeSlugs                   String[]                   @default([])
  createdAt                   DateTime                   @default(now())
  paidAt                      DateTime?
  /// Якщо платіж є частиною підписки річної програми — лінк сюди.
  /// Один Payment = один щомісячний charge; для YEARLY plan створюється один Payment на рік.
  yearlyProgramSubscriptionId String?
  /// Джерело продажу (UIMP за замовчуванням, TETYANA — з персонального сайту Тетяни)
  source                      SaleSource                 @default(UIMP)
  /// orderReference з зовнішньої системи (для продажів з інших сайтів, напр. tetyana-website)
  externalRef                 String?
  yearlyProgramSubscription   YearlyProgramSubscription? @relation("YearlyProgramPayments", fields: [yearlyProgramSubscriptionId], references: [id])
  user                        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                      Course?                    @relation(fields: [courseId], references: [id])
  bundle                      Bundle?                    @relation(fields: [bundleId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([yearlyProgramSubscriptionId])
  @@index([status, createdAt])
  @@index([bundleId])
  @@index([courseId])
  @@index([createdAt])
  @@index([source])
}

/// Сертифікати UIMP — два типи:
/// 1) COURSE — видається автоматично після завершення конкретного курсу на SendPulse.
/// 2) YEARLY_PROGRAM — видається вручну адміном після завершення річної програми,
///    з категорією LISTENER (Слухач) або PRACTICAL (Практична участь).
///
/// Всі ключові поля друкуються на PDF зі snapshot-ів (recipientName, courseName,
/// issueYear), щоб перейменування курсу чи зміна імені юзера не впливали на
/// вже виданий документ. PDF регенерується з БД on-demand за verificationToken.
model Certificate {
  id                 String                      @id @default(cuid())
  /// Людино-читабельний номер для друку: UIMP-COURSE-2026-00042 / UIMP-YEAR-2026-00007
  certNumber         String                      @unique
  /// Непередбачуваний token для публічної верифікації /certificate/{token}. 32 символи nanoid.
  verificationToken  String                      @unique
  type               CertificateType
  /// Тільки для YEARLY_PROGRAM: LISTENER або PRACTICAL. null для COURSE.
  category           CertCategory?

  userId             String
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Для COURSE: id курсу в нашій БД. Для YEARLY — null.
  courseId           String?
  course             Course?                     @relation(fields: [courseId], references: [id])

  /// Для YEARLY_PROGRAM: лінк на підписку, за якою виданий серт.
  subscriptionId     String?
  subscription       YearlyProgramSubscription?  @relation(fields: [subscriptionId], references: [id])

  /// Snapshot recipient name (що буде надруковано) — editable у білдері перед видачею.
  recipientName      String
  recipientEmail     String
  /// Snapshot назви курсу на момент видачі (для COURSE типу).
  courseName         String?
  /// Рік видачі — друкується на сертифікаті (замість baked-in "2026" в JPG).
  issueYear          Int

  issuedAt           DateTime                    @default(now())
  /// null = згенеровано системою (cron); заповнене = видано вручну адміном.
  issuedByUserId     String?
  issuedByName       String?
  issuedByEmail      String?
  /// true = видано через білдер адміном; false = автовидача з крона.
  issuedManually     Boolean                     @default(false)

  /// SHA-256 згенерованого PDF — для integrity checks (audit).
  pdfHash            String?

  emailStatus        CertEmailStatus             @default(PENDING)
  emailSentAt        DateTime?
  emailMessageId     String?
  emailError         String?

  revoked            Boolean                     @default(false)
  revokedAt          DateTime?
  revokedByUserId    String?
  revokedByName      String?
  revokedReason      String?

  events             CertificateEvent[]

  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  /// Запобігає дублям по курсах (для YEARLY поле null → Postgres дозволяє кілька null-ів;
  /// додаткова валідація YEARLY-унікальності робиться на рівні application code).
  @@unique([userId, type, courseId])
  @@index([type, issuedAt])
  @@index([subscriptionId])
  @@index([issuedByUserId])
  @@index([emailStatus])
  @@index([revoked])
}

/// Append-only аудит лог дій над сертифікатами — видно в адмінці ("Історія").
model CertificateEvent {
  id             String      @id @default(cuid())
  certificateId  String
  certificate    Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  /// Хто ініціював подію: adminId, або null якщо system (cron / auto).
  actorId        String?
  actorName      String?
  actorEmail     String?
  /// GENERATED | SENT | RESENT | REVOKED | DOWNLOADED | VIEWED | EMAIL_FAILED
  action         String
  message        String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([certificateId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

enum CertificateType {
  COURSE
  YEARLY_PROGRAM
}

enum CertCategory {
  LISTENER // Слухач — нижча категорія
  PRACTICAL // Практична участь — вища категорія
}

enum CertEmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectorOrder {
  id                 String                      @id @default(cuid())
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  email              String
  fullName           String
  phone              String
  city               String
  postOffice         String
  orderReference     String                      @unique
  amount             Int
  gamePrice          Int?
  shippingCost       Int?
  actualShippingCost Int?
  paymentStatus      PaymentStatus               @default(PENDING)
  paidAt             DateTime?
  orderStatus        OrderStatus                 @default(NEW)
  trackingNumber     String?
  trackingSetAt      DateTime?
  trackingSetById    String?
  trackingSetByName  String?
  trackingSetByEmail String?
  trackingSetByRole  String?
  managerNote        String?
  callMe             Boolean                     @default(false)
  /// Джерело продажу (UIMP за замовчуванням, TETYANA — з персонального сайту Тетяни)
  source             SaleSource                  @default(UIMP)
  /// orderReference з зовнішньої системи
  externalRef        String?
  trackingHistory    ConnectorOrderTrackingLog[]

  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([source])
}

model ConnectorOrderTrackingLog {
  id             String         @id @default(cuid())
  orderId        String
  order          ConnectorOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  value          String
  changedAt      DateTime       @default(now())
  changedById    String?
  changedByName  String?
  changedByEmail String?
  changedByRole  String?

  @@index([orderId])
}

/// Shared-DB: належить tetyana-website (LMS таблицю не використовує).
/// Оголошена тут лише для того, щоб LMS-міграції не видалили її як drift.
model BookingOrder {
  id               String        @id @default(cuid())
  orderReference   String        @unique
  service          String
  method           String
  status           PaymentStatus @default(PENDING)
  amount           Int
  currency         String
  originalAmount   Int
  originalCurrency String
  promoCode        String?
  promoAmount      Int?
  promoCurrency    String?
  clientEmail      String?
  clientName       String?
  clientPhone      String?
  isAdminTest      Boolean       @default(false)
  stripeSessionId  String?
  createdAt        DateTime      @default(now())
  paidAt           DateTime?
  failedAt         DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([service])
  @@index([method])
  @@index([status, createdAt])
}

model News {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  titleEn     String?
  titlePl     String?
  excerptEn   String?
  excerptPl   String?
  contentEn   String?
  contentPl   String?
  imageUrl    String?
  /// Колір фону внутрішньої "сторінки новини" (білий контейнер з блоками). null = дефолтний білий.
  pageBgColor String?
  category    NewsCategory @default(NEWS)
  published   Boolean      @default(false)
  /// Коли задано — новина схована з вітрини. Використовується і для "паузи", і для відкладеної публікації (coupled з resumeAt).
  suspendedAt DateTime?
  /// Коли задано разом з suspendedAt — новина автоматично повертається на вітрину з цієї дати.
  resumeAt    DateTime?
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User?        @relation(fields: [authorId], references: [id])

  @@index([published, createdAt])
}

model NovaPostDivision {
  id          Int      @id
  externalId  Int      @unique
  name        String
  countryCode String
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  status      String?
  category    String?
  syncedAt    DateTime @default(now())

  @@index([countryCode])
  @@index([countryCode, name])
  @@index([countryCode, city])
}

model NovaPostSyncLog {
  id         String   @id @default(cuid())
  syncedAt   DateTime @default(now())
  totalCount Int
  status     String
  message    String?
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SaleSource {
  UIMP
  TETYANA
}

enum SubscriptionPlan {
  MONTHLY
  SIX_MONTHS
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  SENDPULSE
  LOCAL
}

model Bundle {
  id          String         @id @default(cuid())
  title       String
  titleEn     String?
  titlePl     String?
  description String?
  slug        String         @unique
  price       Int
  imageUrl    String?
  published   Boolean        @default(false)
  suspendedAt DateTime?
  resumeAt    DateTime?
  /// Тип пакету: DISCOUNT — стара логіка зі знижкою; FIXED_FREE — N платних + M безкоштовних фіксованих; CHOICE_FREE — N платних + пул безкоштовних (клієнт обирає freeCount)
  type        BundleType     @default(DISCOUNT)
  /// Очікувана кількість платних курсів у пакеті (для валідації UI/checkout)
  paidCount   Int            @default(2)
  /// Кількість безкоштовних, які клієнт отримує при покупці (0 для DISCOUNT)
  freeCount   Int            @default(0)
  /// Позиція у списку (менше = вище). Drag-and-drop reorder в адмінці.
  sortOrder   Int            @default(0)
  /// Номер ряду на публічній /courses (bundles з однаковим rowGroup ідуть у тому ж ряду). null = ще не згруповано, fallback до pack-by-2.
  rowGroup    Int?
  /// Режим відображення на публічній /courses: 'solo' — завжди один в ряду (за замовчуванням); 'auto' — групується з іншими тієї самої ширини.
  displayMode String         @default("solo")
  createdAt   DateTime       @default(now())
  courses     BundleCourse[]
  payments    Payment[]

  @@index([sortOrder])
  /// Прискорює основний публічний запит /courses: where published=true AND suspendedAt IS NULL ORDER BY sortOrder, createdAt
  @@index([published, suspendedAt, sortOrder, createdAt])
  /// Прискорює auto-resume cron: where suspendedAt IS NOT NULL AND resumeAt <= now()
  @@index([suspendedAt, resumeAt])
}

model BundleCourse {
  id         String  @id @default(cuid())
  bundleId   String
  courseSlug String
  /// true — курс безкоштовний у цьому пакеті (для FIXED_FREE — видається всім; для CHOICE_FREE — кандидат у пул)
  isFree     Boolean @default(false)
  bundle     Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseSlug])
  @@index([bundleId])
}

enum BundleType {
  DISCOUNT
  FIXED_FREE
  CHOICE_FREE
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  courseId      String?
  maxUses       Int?
  usedCount     Int          @default(0)
  active        Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  course        Course?      @relation(fields: [courseId], references: [id])

  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum NewsCategory {
  NEWS
  ANNOUNCEMENT
  ARTICLE
  EVENT
}

/// Лог усіх платіжних callback-ів (course / bundle / connector).
/// Пишеться ЗАВЖДИ — навіть для invalid signature, retry або idempotent skip.
model PaymentCallbackLog {
  id                String   @id @default(cuid())
  source            String // "wayforpay" | "manual" | ...
  kind              String // "course" | "bundle" | "connector" | "unknown"
  orderReference    String?
  transactionStatus String? // Approved / Declined / Expired / InProcessing / ...
  amount            Int?
  currency          String?
  clientEmail       String?
  ip                String?
  userAgent         String?
  signatureValid    Boolean?
  prevStatus        String? // статус Payment/ConnectorOrder ДО цього callback
  actionsTaken      String? // "payment:updated,enrollment:created,sendpulse:sent(2)"
  sendpulseSlugs    String? // слаги курсів, по яких реально відправлено events
  skipped           Boolean  @default(false)
  skipReason        String?
  rawPayload        Json?
  error             String?
  createdAt         DateTime @default(now())

  @@index([orderReference])
  @@index([createdAt])
  @@index([kind])
}

/// Підписка на Річну програму (навчальна програма на платформі SendPulse).
/// YEARLY = одна оплата, доступ на 1 рік. MONTHLY = щомісячне авто-списання через WayForPay recToken,
/// при кожному успішному charge expiresAt продовжується на +30 днів. Доступ до SendPulse
/// курсу відкривається подією (SENDPULSE_EVENT_URL) і закривається через Education API
/// (DELETE /students/{studentId}/{courseId}).
model YearlyProgramSubscription {
  id              String                          @id @default(cuid())
  userId          String
  user            User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            YearlyProgramPlan
  status          YearlyProgramSubscriptionStatus @default(PENDING)
  /// Для MONTHLY плану: true — автосписання ввімкнено (9 платежів через WFP recToken);
  /// false — разова оплата за 1 місяць без рекурентних списань.
  /// Для YEARLY плану завжди false (у річної немає рекурентних списань).
  autoRenew       Boolean                         @default(false)
  startDate       DateTime?
  /// Для YEARLY = startDate + 1 рік. Для MONTHLY = останній успішний charge + 30 днів.
  expiresAt       DateTime?
  cancelledAt     DateTime?
  cancelledBy     String? // "user" | "admin" | "system"
  cancelledReason String?

  /// WayForPay tokenization — для авто-списання MONTHLY плану.
  recToken            String?
  /// Опційно: orderReference запису в regularApi (якщо колись перейдемо на WFP-managed schedule).
  wfpRegularRef       String?
  lastPaymentAt       DateTime?
  lastChargeAttemptAt DateTime?
  lastChargeError     String?
  failedChargeCount   Int       @default(0)

  /// SendPulse Education API — studentId (integer) для виклику DELETE /students/{id}/{courseId}.
  /// Лук-апимо через POST /students/by-course/{courseId} по email після першої оплати.
  sendpulseStudentId      Int?
  sendpulseAccessOpenedAt DateTime?
  sendpulseAccessClosedAt DateTime?

  /// Прогрес у курсі "Річна програма" (SENDPULSE_YEARLY_COURSE_ID).
  /// Оновлюється щоденним cron-ом `/api/cron/yearly-subscriptions`.
  spProgressPercent   Int?
  spProgressCheckedAt DateTime?

  /// Момент переходу ACTIVE→GRACE + розрахована межа закінчення grace-періоду.
  /// expiresAt + graceDays НЕ використовуємо як фільтр expireGraceSubscriptions, бо при
  /// пропущеному cron-добу підписка потрапляє в GRACE з expiresAt глибоко в минулому —
  /// це б миттєво expire-ало її. Ми фіксуємо, коли саме GRACE почалось, і експайраємо
  /// лише коли `gracePeriodEndsAt < now`.
  graceStartedAt    DateTime?
  gracePeriodEndsAt DateTime?

  /// Нагадування про закінчення / grace.
  /// MANUAL flow: manualBeforeExpiry (3д до) → manualOnExpiry (день 0) → manualGraceStart (день +1) → accessClosed (день +7)
  /// CYCLICAL flow (тільки при charge failure): cyclicalChargeFailed1 (день +1) → cyclicalChargeFailed3 (день +3) → accessClosed (день +7)
  reminderSent3d         Boolean @default(false) /// manual: 3 дні до закінчення
  reminderSentExpired    Boolean @default(false) /// spіvlynyi: accessClosed на день +7
  reminderSentOnExpiry   Boolean @default(false) /// manual: у день закінчення
  reminderSentGraceStart Boolean @default(false) /// manual: день +1 (grace стартував) АБО cyclical: charge failed
  reminderSentGraceMid   Boolean @default(false) /// cyclical: день +3 (все ще не списано)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments     Payment[]                        @relation("YearlyProgramPayments")
  events       YearlyProgramSubscriptionEvent[]
  certificates Certificate[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([status, expiresAt])
  @@index([plan, status, expiresAt])
}

/// Лог важливих подій підписки — видно в адмінці для прозорості й дебагу.
model YearlyProgramSubscriptionEvent {
  id             String                    @id @default(cuid())
  subscriptionId String
  subscription   YearlyProgramSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  /// "created" | "renewed" | "charge_attempt" | "charge_success" | "charge_failed"
  /// | "access_opened" | "access_closed" | "reminder_3d" | "reminder_1d" | "reminder_expired"
  /// | "cancelled" | "reactivated" | "admin_action"
  type           String
  message        String?
  metadata       Json?
  createdAt      DateTime                  @default(now())

  @@index([subscriptionId])
  @@index([createdAt])
  @@index([type])
}

enum YearlyProgramPlan {
  YEARLY
  MONTHLY
}

enum YearlyProgramSubscriptionStatus {
  PENDING // створено, перша оплата ще не пройшла
  ACTIVE // доступ відкритий, expiresAt у майбутньому
  GRACE // expiresAt у минулому, але в межах grace-періоду (1 день)
  EXPIRED // доступ закрито, списання припинено
  CANCELLED // юзер/адмін скасував регулярку
  ARCHIVED // адмін заархівував (доступ SendPulse закритий, tech-поля очищені, reopen заблокований)
}

/// Override-и динамічних полів спеціалістів (ціна, тривалість, кнопка запису, приховування).
/// Базовий контент (імʼя, опис, освіта, сертифікати) лишається у TS-файлах
/// `app/[locale]/consultations/_content/*.ts`. Ключ — slug, що дорівнює slug-у в TS.
model SpecialistOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  price     String?
  duration  String?
  btnLabel  String?
  btnUrl    String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Override ціни курсу для керування з адмінки без деплою.
/// Ключ — slug із `lib/coursesCatalog.ts`. Якщо відповідне поле не null —
/// воно перекриває значення з config.ts/каталогу. Відсутність рядка = повний дефолт.
/// `oldPrice` — стара ціна, що рендериться перекресленою поруч із новою (тільки на
/// детальних сторінках курсів; у списку /courses завжди видно тільки актуальну ціну).
model CoursePriceOverride {
  id        String   @id @default(cuid())
  slug      String   @unique
  price     Int?
  oldPrice  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Generic key-value store для app-рівневих налаштувань, які треба змінювати
/// runtime без redeploy. Перший споживач — `yearlyGraceDays` (тривалість grace
/// періоду Річної програми у днях). Fallback на дефолт із коду, якщо запис відсутній.
model AppSetting {
  key       String   @id
  value     Int
  updatedAt DateTime @updatedAt
}
