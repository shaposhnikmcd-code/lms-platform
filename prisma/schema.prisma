generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime       @default(now())
  lastLoginAt   DateTime?
  role          UserRole       @default(STUDENT)
  accounts      Account[]
  enrollments   Enrollment[]
  sessions      Session[]
  progress      CourseProgress[]
  lessonProgress LessonProgress[]
  payments      Payment[]
  certificates  Certificate[]
  subscriptions Subscription[]
  courseTeachers CourseTeacher[]
  sentMessages     Message[]   @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  news          News[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id           String           @id @default(cuid())
  title        String
  description  String
  price        Int
  published    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  imageUrl     String?
  slug         String?          @unique
  enrollments  Enrollment[]
  modules      Module[]
  progress     CourseProgress[]
  payments     Payment[]
  certificates Certificate[]
  courseTeachers CourseTeacher[]
}

model CourseTeacher {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  courseId   String?
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Module {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String           @id @default(cuid())
  title          String
  order          Int
  moduleId       String
  content        String?
  videoUrl       String?
  videoProvider  VideoProvider    @default(YOUTUBE)
  videoId        String?
  duration       Int?
  isFree         Boolean          @default(false)
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress[]
  lessonProgress LessonProgress[]
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  watchedAt   Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model CourseProgress {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  lastLessonId    String?
  progressPercent Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lastLesson      Lesson?   @relation(fields: [lastLessonId], references: [id])

  @@unique([userId, courseId])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  courseId       String?
  orderReference String        @unique
  amount         Int
  currency       String        @default("UAH")
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  paidAt         DateTime?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course?       @relation(fields: [courseId], references: [id])
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  issuedAt       DateTime @default(now())
  certificateUrl String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectorOrder {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  email          String
  fullName       String
  phone          String
  city           String
  postOffice     String
  orderReference String        @unique
  amount         Int
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  orderStatus    OrderStatus   @default(NEW)
  trackingNumber String?
  managerNote    String?
  callMe         Boolean       @default(false)
}

model News {
  id        String       @id @default(cuid())
  title     String
  slug      String       @unique
  content   String
  excerpt   String?
  imageUrl  String?
  category  NewsCategory @default(NEWS)
  published Boolean      @default(false)
  authorId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  author    User?        @relation(fields: [authorId], references: [id])
}

model NovaPostDivision {
  id          Int      @id
  externalId  Int      @unique
  name        String
  countryCode String
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  status      String?
  category    String?
  syncedAt    DateTime @default(now())

  @@index([countryCode])
  @@index([countryCode, name])
  @@index([countryCode, city])
}

model NovaPostSyncLog {
  id          String   @id @default(cuid())
  syncedAt    DateTime @default(now())
  totalCount  Int
  status      String
  message     String?
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  STUDENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionPlan {
  MONTHLY
  SIX_MONTHS
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  SENDPULSE
  LOCAL
}

enum NewsCategory {
  NEWS
  ANNOUNCEMENT
  ARTICLE
}